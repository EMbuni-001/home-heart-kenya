# =============================================================================
# UpCare — Environment Variable Template
# =============================================================================
# Copy this file to `.env.local` for local development, or paste these keys
# into Vercel → Project Settings → Environment Variables for SSR deploys.
#
# Rules:
#   - VITE_* values are PUBLIC. They are bundled into the client JS and
#     visible to anyone who opens the site. Never put secrets here.
#   - Unprefixed values are SERVER-ONLY. They are read via `process.env.X`
#     inside `createServerFn` handlers or server route handlers and never
#     reach the browser.
#   - On Vercel, set every variable for all three environments
#     (Production, Preview, Development) unless noted otherwise.
# =============================================================================


# -----------------------------------------------------------------------------
# Build target (required on Vercel)
# -----------------------------------------------------------------------------
# Tells Nitro to emit Vercel's Build Output API format. Already wired in
# `vercel.json`, but listed here so local `vite build` can mimic the prod
# build with: `NITRO_PRESET=vercel vite build`.
NITRO_PRESET=vercel


# -----------------------------------------------------------------------------
# Node runtime (optional)
# -----------------------------------------------------------------------------
# Vercel sets this automatically in deploys. Override locally if needed.
# NODE_ENV=production


# -----------------------------------------------------------------------------
# Public site config (safe to expose — bundled into the client)
# -----------------------------------------------------------------------------
# Canonical origin used by the sitemap route and share/OG links.
VITE_SITE_URL=https://your-deployment.vercel.app

# Public app name shown in the UI / document title fallback.
VITE_APP_NAME=UpCare


# -----------------------------------------------------------------------------
# Lovable Cloud / Supabase (only if you enable Lovable Cloud)
# -----------------------------------------------------------------------------
# These are auto-provisioned by Lovable when Cloud is enabled. Copy the
# values from Lovable → Project Settings → Cloud, then mirror them into
# Vercel. The publishable key is safe in the client; the service role key
# is server-only and bypasses RLS — never prefix it with VITE_.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Lovable AI Gateway (only if you call AI from server functions)
# -----------------------------------------------------------------------------
# Provisioned by Lovable. Server-only — read inside `.handler()`.
# LOVABLE_API_KEY=


# -----------------------------------------------------------------------------
# Optional integrations — uncomment the ones you actually use
# -----------------------------------------------------------------------------
# SMS / reminder delivery (e.g. Twilio):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Transactional email (e.g. Resend):
# RESEND_API_KEY=

# Payment processing (Stripe):
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY=
